  "validation_rules": [
    {"rule": "dimension_range", "condition": "breite >= 600 AND breite <= 1500", "error": "zulässiger Bereich von 600 bis 1500 mm"},
    {"rule": "dimension_range", "condition": "hoehe >= 450 AND hoehe <= 1700", "error": "zulässiger Bereich von 450 bis 1700 mm"},
    {"rule": "aspect_ratio", "condition": "Server-side check on width/height ratio", "error": "Verhältnis Breite/Höhe nicht zulässig"},
    {"rule": "required_config", "condition": "All required fields present in obj_konfig", "error": "Fehlende Konfiguration"},
    {"rule": "roller_shutter_width", "condition": "breite / roll_teil <= max roller width", "error": "Rollladenbreite zu groß"}
  ]
