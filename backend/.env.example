# ===========================================
# CURIA Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3001
NODE_ENV=development

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=curia
DB_USER=postgres
DB_PASSWORD=your_password_here

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# SECURITY
# ===========================================
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SESSION_TIMEOUT_MS=1800000

# ===========================================
# CORS (comma-separated origins)
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ===========================================
# EMAIL (for later - leave empty for now)
# ===========================================
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@curia.app
SENDGRID_API_KEY=

# ===========================================
# BUSINESS SETTINGS
# ===========================================
DEFAULT_MARGIN=0.50
DEFAULT_VAT_RATE=0.19
DEFAULT_CURRENCY=EUR
DEFAULT_LOCALE=de-DE

# ===========================================
# LEAD GENERATOR (CREATOR-ONLY)
# ===========================================
LEAD_GENERATOR_ENABLED=true

# ===========================================
# VAT VALIDATION (VIES API for B2B)
# ===========================================
VIES_VALIDATION_ENABLED=true

# ===========================================
# CONFIGURATION SHARING
# ===========================================
CONFIG_SHARE_URL_PREFIX=/configure?config=

# ===========================================
# GOOGLE ANALYTICS 4 (Optional)
# ===========================================
GA4_ENABLED=false
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# ===========================================
# FRONTEND URL (for CORS in production)
# ===========================================
FRONTEND_URL=
