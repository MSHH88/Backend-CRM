{
  "name": "curia-backend",
  "version": "1.0.0",
  "description": "CURIA CRM Backend - Window/Door Configurator E-Commerce Platform",
  "main": "src/server.js",
  "scripts": {
    "prestart": "node src/checkSetup.js",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "check": "node src/checkSetup.js",
    "test": "jest --testEnvironment=node --forceExit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\""
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "keywords": [
    "crm",
    "ecommerce",
    "configurator",
    "windows",
    "doors"
  ],
  "author": "CURIA Development Team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.1",
    "supertest": "^6.3.4"
  }
}
